    "RoA_A01_M02_SCRN_006": {
      "hash": "b9457b11ee",
      "string_number": 291,
      "type": "SCRN",
      "source": "|cffffcc00TECHTREE UNLOCKED|r\nShipyards are primarily responsible for constructing various warships within the Alliance's naval forces. They also serve as depots for harvested oil."
    },
    "RoA_A01_M02_SCRN_007": {
      "hash": "7d4557fab5",
      "string_number": 292,
      "type": "SCRN",
      "source": "|cffffcc00TECHTREE UNLOCKED|r\nElven Destroyers are powerful warships from the fleets of Quel'thalas. Crewed with highly-skilled Elven seafarers, these swift-sailing vessels are prepared to engage the enemy wherever they may be found."
    },
